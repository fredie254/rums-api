# =
# RUMS Standalone REST API — Environment Configuration
# Copy to .env and fill in values. Never commit .env.
# =

# ── Application ───────────────────────────────────────────────
APP_NAME=
APP_VERSION=
APP_ENV=
APP_DEBUG=
APP_TIMEZONE=
APP_URL=

# ── Database ──────────────────────────────────────────────────
DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASS=
DB_CHARSET=

# ── API Security ──────────────────────────────────────────────
APP_KEY=
API_RATE_LIMIT=
API_RATE_WINDOW=
API_TOKEN_LENGTH=
API_TOKEN_EXPIRY_DAYS=

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated origins, or * for any
CORS_ALLOWED_ORIGINS=

# ── Logging ───────────────────────────────────────────────────
LOG_CHANNEL=
LOG_PATH=

# ── Currency ──────────────────────────────────────────────────
CURRENCY_SYMBOL=
CURRENCY_CODE=
